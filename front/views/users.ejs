<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            background: #f5f5f5;
        }

        nav {
            background: #333;
            color: white;
            padding: 15px 0;
        }

        nav a {
            color: white;
            margin: 0 20px;
            text-decoration: none;
        }

        nav a:hover {
            color: #4CAF50;
        }

        main {
            max-width: 1200px;
            margin: 20px auto;
            padding: 20px;
            background: white;
            border-radius: 8px;
        }

        h1 {
            margin-bottom: 20px;
            color: #333;
        }

        form {
            background: #f9f9f9;
            padding: 20px;
            border-radius: 5px;
            margin-bottom: 30px;
        }

        form label {
            display: block;
            margin-top: 10px;
            font-weight: bold;
        }

        form input {
            width: 100%;
            padding: 8px;
            margin-top: 5px;
            border: 1px solid #ddd;
            border-radius: 4px;
        }

        form button {
            margin-top: 15px;
            padding: 10px 20px;
            margin-right: 10px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
        }

        form button[type="submit"] {
            background: #4CAF50;
            color: white;
        }

        form button[type="reset"] {
            background: #999;
            color: white;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        th,
        td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }

        th {
            background: #333;
            color: white;
        }

        tr:hover {
            background: #f5f5f5;
        }

        .btn {
            padding: 6px 12px;
            margin: 0 5px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
        }

        .btn-editar {
            background: #2196F3;
            color: white;
        }

        .btn-deletar {
            background: #f44336;
            color: white;
        }

        .error {
            color: red;
            margin-bottom: 10px;
            font-weight: bold;
        }
    </style>
</head>

<body>
    <nav>
        <a href="/">🏠 Home</a>
        <a href="/users">👥 Usuários</a>
        <a href="/pets">🐾 Pets</a>
    </nav>
    <main>
        <h1>
            <%= title %>
        </h1>
        <form id="userForm">
            <input type="hidden" id="id">
            <label for="username">Nome</label>
            <input name="username" id="username" type="text" required><br>
            <label for="password">Senha</label>
            <input name="password" id="password" type="password" required><br>
            <label for="email">Email</label>
            <input name="email" id="email" type="email" required><br>
            <label for="phone">Telefone</label>
            <input name="phone" id="phone" type="text" required><br>
            <button type="submit">Enviar</button>
            <button type="reset">Cancelar</button>
        </form>
        <% if(error){ %>
            <div class="error">
                <%= error %>
            </div>
            <% } %>
                <table border="1">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nome</th>
                            <th>Email</th>
                            <th>Telefone</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for(let user of users){ %>
                            <tr>
                                <td>
                                    <%= user.id %>
                                </td>
                                <td>
                                    <%= user.username %>
                                </td>
                                <td>
                                    <%= user.email %>
                                </td>
                                <td>
                                    <%= user.phone %>
                                </td>
                                <td>
                                    <button class="btn btn-editar"
                                        onclick="editarUsuario('<%= user.id %>')">Editar</button>
                                    <button class="btn btn-deletar"
                                        onclick="deletarUsuario('<%= user.id %>')">Deletar</button>
                                </td>
                            </tr>
                            <% } %>
                    </tbody>
                </table>
    </main>
    <script>
        const form = document.getElementById('userForm');
        const idInput = document.getElementById('id');

        form.addEventListener("submit", (e) => {
            e.preventDefault();
            const user = {
                username: document.getElementById('username').value,
                password: document.getElementById('password').value,
                email: document.getElementById('email').value,
                phone: document.getElementById('phone').value
            };
            if (idInput.value) {
                atualizarUsuario(idInput.value, user);
            } else {
                criarUsuario(user);
            }
        });

        function criarUsuario(user) {
            fetch('/users/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(user)
            })
                .then(res => res.json())
                .then(data => {
                    alert('Usuário criado!');
                    form.reset();
                    idInput.value = '';
                    location.reload();
                })
                .catch(err => console.error('Erro:', err));
        }

        function atualizarUsuario(id, user) {
            fetch(`/users/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(user)
            })
                .then(res => res.json())
                .then(data => {
                    alert('Usuário atualizado!');
                    form.reset();
                    idInput.value = '';
                    location.reload();
                })
                .catch(err => console.error('Erro:', err));
        }

        function editarUsuario(id) {
            fetch(`/users/${id}`)
                .then(res => res.json())
                .then(user => {
                    document.getElementById('id').value = user.id;
                    document.getElementById('username').value = user.username;
                    document.getElementById('password').value = user.password;
                    document.getElementById('email').value = user.email;
                    document.getElementById('phone').value = user.phone;
                    form.scrollIntoView({ behavior: 'smooth' });
                })
                .catch(err => console.error('Erro:', err));
        }

        function deletarUsuario(id) {
            if (confirm('Tem certeza?')) {
                fetch(`/users/${id}`, { method: 'DELETE' })
                    .then(res => res.json())
                    .then(data => {
                        alert('Deletado!');
                        location.reload();
                    })
                    .catch(err => console.error('Erro:', err));
            }
        }
    </script>
</body>

</html>