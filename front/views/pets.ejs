<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pets - Petshop</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            background: #f5f5f5;
        }

        nav {
            background: #333;
            color: white;
            padding: 15px 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 20px;
        }

        nav a {
            color: white;
            margin: 0 15px;
            text-decoration: none;
        }

        nav a:hover {
            color: #FF9800;
        }

        nav button {
            background: #d32f2f;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
        }

        nav button:hover {
            background: #c62828;
        }

        main {
            max-width: 1200px;
            margin: 20px auto;
            padding: 20px;
            background: white;
            border-radius: 8px;
        }

        h1 {
            margin-bottom: 20px;
            color: #333;
        }

        form {
            background: #f9f9f9;
            padding: 20px;
            border-radius: 5px;
            margin-bottom: 30px;
        }

        .form-group {
            margin-bottom: 15px;
        }

        label {
            display: block;
            font-weight: bold;
            margin-bottom: 5px;
        }

        input,
        select {
            width: 100%;
            padding: 8px;
            border: 1px solid #ddd;
            border-radius: 4px;
        }

        button[type="submit"] {
            background: #FF9800;
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
            width: auto;
        }

        button[type="submit"]:hover {
            background: #F57C00;
        }

        button[type="reset"] {
            background: #999;
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
            margin-left: 10px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        th,
        td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }

        th {
            background: #FF9800;
            color: white;
        }

        tr:hover {
            background: #f5f5f5;
        }

        .btn {
            padding: 6px 12px;
            margin: 0 5px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 12px;
        }

        .btn-editar {
            background: #2196F3;
            color: white;
        }

        .btn-deletar {
            background: #f44336;
            color: white;
        }

        .tutor-badge {
            background: #4CAF50;
            color: white;
            padding: 4px 8px;
            border-radius: 3px;
            font-size: 12px;
        }
    </style>
</head>

<body>
    <nav>
       <nav>
        <a href="/">🏠 Home</a>
        <a href="/servicos">🛁 Serviços</a>
        <a href="/customers">👥 Customers</a>
        <a href="/agendamentos">📅 Agendamentos</a>
    </nav>
        <button onclick="logout()">🚪 Sair</button>
    </nav>

    <main>
        <h1>🐾 Gestão de Pets</h1>

        <form id="petForm">
            <input type="hidden" id="id">

            <div class="form-group">
                <label for="name">Nome do Pet</label>
                <input name="name" id="name" type="text" required>
            </div>

            <div class="form-group">
                <label for="type">Tipo</label>
                <select name="type" id="type" required>
                    <option value="">Selecione...</option>
                    <option value="Cachorro">Cachorro</option>
                    <option value="Gato">Gato</option>
                    <option value="Passaro">Pássaro</option>
                    <option value="Coelho">Coelho</option>
                    <option value="Hamster">Hamster</option>
                    <option value="Tartaruga">Tartaruga</option>
                    <option value="Outro">Outro</option>
                </select>
            </div>

            <div class="form-group">
                <label for="race">Raça</label>
                <input name="race" id="race" type="text" required>
            </div>

            <div class="form-group">
                <label for="colour">Cor</label>
                <input name="colour" id="colour" type="text" required>
            </div>

            <div class="form-group">
                <label for="gender">Gênero</label>
                <select name="gender" id="gender" required>
                    <option value="">Selecione...</option>
                    <option value="Macho">Macho</option>
                    <option value="Fêmea">Fêmea</option>
                </select>
            </div>

            <div class="form-group">
                <label for="customer_id">👤 Customer (Dono)</label>
                <select name="customer_id" id="customer_id" required>
                    <option value="">Selecione um customer...</option>
                </select>
            </div>

            <button type="submit">Salvar</button>
            <button type="reset">Cancelar</button>
        </form>

        <table border="1">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nome</th>
                    <th>Tipo</th>
                    <th>Raça</th>
                    <th>Cor</th>
                    <th>Gênero</th>
                    <th>👤 Customer</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody id="petsTable">
            </tbody>
        </table>
    </main>

    <script>
        // Variáveis globais - [Seu Nome]
        const API_URL = 'https://fluffy-tribble-vx7r9vp5v7j2579-3000.app.github.dev/pets';
        const CUSTOMERS_API_URL = 'https://fluffy-tribble-vx7r9vp5v7j2579-3000.app.github.dev/customers';
        const token = localStorage.getItem('token');
        const form = document.getElementById('petForm');
        const idInput = document.getElementById('id');

        if (!token) {
            alert('Você precisa estar autenticado');
            window.location.href = '/login';
        }

        carregarPets();
        carregarCustomers();

        form.addEventListener("submit", (e) => {
            e.preventDefault();

            const pet = {
                name: document.getElementById('name').value,
                type: document.getElementById('type').value,
                race: document.getElementById('race').value,
                colour: document.getElementById('colour').value,
                gender: document.getElementById('gender').value,
                customer_id: parseInt(document.getElementById('customer_id').value)
            };

            if (!pet.customer_id) {
                alert('Selecione um customer!');
                return;
            }

            if (idInput.value) {
                atualizarPet(idInput.value, pet);
            } else {
                criarPet(pet);
            }
        });

        function carregarPets() {
            fetch(API_URL, {
                headers: { 'Authorization': `Bearer ${token}` }
            })
                .then(res => res.json())
                .then(pets => {
                    const tabela = document.getElementById('petsTable');
                    tabela.innerHTML = '';

                    if (Array.isArray(pets) && pets.length > 0) {
                        pets.forEach(p => {
                            const customerDisplay = p.customer_name
                                ? `<span class="tutor-badge">${p.customer_name}</span>`
                                : `<span style="color: #999;">Sem customer</span>`;

                            const row = `
        <tr>
            <td>${p.id}</td>
            <td>${p.name}</td>
            <td>${p.type}</td>
            <td>${p.race}</td>
            <td>${p.colour}</td>
            <td>${p.gender}</td>
            <td>${customerDisplay}</td>
            <td>
                <button class="btn btn-editar" onclick="editarPet(${p.id})">Editar</button>
                <button class="btn btn-deletar" onclick="deletarPet(${p.id})">Deletar</button>
            </td>
        </tr>
    `;
                            tabela.innerHTML += row;
                        });
                    } else {
                        tabela.innerHTML = '<tr><td colspan="8" style="text-align:center;">Nenhum pet cadastrado</td></tr>';
                    }
                })
                .catch(err => console.error('Erro:', err));
        }

        function carregarCustomers() {
            fetch(CUSTOMERS_API_URL, {
                headers: { 'Authorization': `Bearer ${token}` }
            })
                .then(res => res.json())
                .then(customers => {
                    const select = document.getElementById('customer_id');
                    select.innerHTML = '<option value="">Selecione um customer...</option>';

                    if (Array.isArray(customers) && customers.length > 0) {
                        customers.forEach(c => {
                            const option = document.createElement('option');
                            option.value = c.id;
                            option.textContent = c.username;
                            select.appendChild(option);
                        });
                    } else {
                        const option = document.createElement('option');
                        option.disabled = true;
                        option.textContent = 'Nenhum customer disponível';
                        select.appendChild(option);
                    }
                })
                .catch(err => console.error('Erro:', err));
        }

        function criarPet(pet) {
            fetch(API_URL, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                },
                body: JSON.stringify(pet)
            })
                .then(res => res.json())
                .then(data => {
                    alert('Pet criado!');
                    form.reset();
                    idInput.value = '';
                    carregarPets();
                })
                .catch(err => {
                    console.error('Erro:', err);
                    alert('Erro ao criar pet!');
                });
        }

        function atualizarPet(id, pet) {
            fetch(`${API_URL}/${id}`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                },
                body: JSON.stringify(pet)
            })
                .then(res => res.json())
                .then(data => {
                    alert('Pet atualizado!');
                    form.reset();
                    idInput.value = '';
                    carregarPets();
                })
                .catch(err => {
                    console.error('Erro:', err);
                    alert('Erro ao atualizar pet!');
                });
        }

        function editarPet(id) {
            fetch(`${API_URL}/${id}`, {
                headers: { 'Authorization': `Bearer ${token}` }
            })
                .then(res => res.json())
                .then(pet => {
                    document.getElementById('id').value = pet.id;
                    document.getElementById('name').value = pet.name;
                    document.getElementById('type').value = pet.type;
                    document.getElementById('race').value = pet.race;
                    document.getElementById('colour').value = pet.colour;
                    document.getElementById('gender').value = pet.gender;
                    document.getElementById('customer_id').value = pet.customer_id || '';
                    form.scrollIntoView({ behavior: 'smooth' });
                })
                .catch(err => {
                    console.error('Erro:', err);
                    alert('Erro ao buscar pet!');
                });
        }

        function deletarPet(id) {
            if (confirm('Tem certeza que deseja deletar este pet?')) {
                fetch(`${API_URL}/${id}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': `Bearer ${token}` }
                })
                    .then(res => res.json())
                    .then(data => {
                        alert('Pet deletado!');
                        carregarPets();
                    })
                    .catch(err => {
                        console.error('Erro:', err);
                        alert('Erro ao deletar pet!');
                    });
            }
        }

        // Logout - [Seu Nome]
        function logout() {
            localStorage.removeItem('token');
            localStorage.removeItem('user');
            document.cookie = 'token=; path=/; max-age=0';
            window.location.href = '/login';
        }
    </script>
</body>

</html>